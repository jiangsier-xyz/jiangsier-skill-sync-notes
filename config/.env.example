# sync-notes — non-rclone settings consumed by scripts/sync.sh
#
# Copy this file to `.env` and adjust, OR run scripts/setup.sh which writes
# `.env` (chmod 600) for you.

# Name of the crypt remote defined in rclone.conf. Must match the section
# header used in rclone.conf (default: `notes`).
RCLONE_REMOTE=notes

# Number of local backup snapshots to retain under backups/.
# The script currently keeps a single rolling copy at backups/latest/, so
# values >1 are reserved for future use.
BACKUP_KEEP=1

# Extra flags appended to every rclone invocation. Tune for your network.
RCLONE_EXTRA_FLAGS="--transfers=4 --checkers=8"
